# Copy this to .env and fill in your keys

# TheOddsAPI — get a free key at https://the-odds-api.com
# Free tier: 500 requests/month (enough for daily NHL analysis)
# Includes Betway, Bet365, William Hill, and 40+ other books
ODDS_API_KEY=your_key_here

# Optional: Anthropic Claude for AI research agent
ANTHROPIC_API_KEY=your_key_here

# Optional: OpenAI-compatible endpoint (OpenClaw, Ollama, OpenRouter)
# OPENAI_API_KEY=your_key_here
# OPENAI_BASE_URL=http://localhost:18789/v1
